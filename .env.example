# ====================================================================
# BHARAT STEEL GROUP — EXPENSE PORTAL · ENVIRONMENT CONFIGURATION
# ====================================================================
# Copy this file to `.env` and fill in real values before running the
# server. Never commit the real `.env` file to git.
# ====================================================================

# --- Server ---
NODE_ENV=production
PORT=3000
# The public URL your users will visit. Used for OAuth callbacks &
# absolute links in emails. NO TRAILING SLASH.
APP_URL=http://localhost:3000

# --- Session ---
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_a_long_random_string

# ====================================================================
#  SIGN-IN METHODS
#  The portal supports three, auto-selected per employee by email domain:
#    @metfraa.com  -> Microsoft 365 SSO   (uses the MS_* vars below)
#    @gmail.com    -> Google SSO          (uses the GOOGLE_* vars below)
#    anything else -> portal password     (no extra config; default Metfraa@123)
#  Sign-in is gated by the EMPLOYEE DATABASE: only people seeded or added
#  in the admin panel can log in, regardless of method.
# ====================================================================

# --- Google OAuth (only needed if you have @gmail.com employees) ---
# Create OAuth 2.0 credentials in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be: {APP_URL}/auth/google/callback
# Leave blank if you have no Gmail users — the Google button simply won't work.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# (legacy/advisory only — not enforced at login)
ALLOWED_HD_DOMAINS=metfraa.com


# --- Email (SMTP) ---
# Works with any SMTP provider: Gmail, Resend, SendGrid, Postmark,
# Office 365, your own server, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=portal@bharatsteels.in
SMTP_PASS=your-smtp-password-or-app-password
# Sender shown in HR's inbox (must be authorised by your SMTP provider)
SMTP_FROM_NAME=Bharat Steel Group Portal
SMTP_FROM_EMAIL=portal@bharatsteels.in

# --- HR Routing (recipients per company / form-type) ---
# Comma-separated lists are supported.
BSC_HR_EMAIL=hr@bharatsteels.in
BSC_EA_EMAIL=ea@bharatsteels.in
METFRAA_HR_EMAIL=admin@metfraa.com

# --- Uploads ---
# Max file size for individual bill uploads, in MB.
UPLOAD_MAX_MB=10
# Max combined uploads per submission, in MB.
UPLOAD_TOTAL_MAX_MB=50

# --- Admin ---
# Comma-separated Google emails that can access the admin panel
# (view all submissions, manage employees).
ADMIN_EMAILS=admin@metfraa.com,hr@metfraa.com,info@metfraa.com,arasu@metfraa.com

# --- Microsoft 365 / Graph (used for BOTH OneDrive storage AND Microsoft SSO) ---
# The same "Metfraa-Reimbursements" Azure app powers two things:
#   1. OneDrive file/Excel storage  -> APPLICATION perm: Files.ReadWrite.All (admin-consented)
#   2. Microsoft SSO employee login -> DELEGATED perm: User.Read
#                                      + Redirect URI (Web): {APP_URL}/auth/microsoft/callback
# Create a client secret under "Certificates & secrets" and paste its Value below.
MS_TENANT_ID=your-azure-tenant-id
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
# Whose OneDrive to store into (the account that owns the folder structure):
ONEDRIVE_TARGET_USER=info@metfraa.com
# Root folder name created under that user's OneDrive:
ONEDRIVE_ROOT_FOLDER=Reimbursements and Conveyance
# Background retry interval (minutes) for re-syncing anything that failed:
ONEDRIVE_RETRY_MINUTES=15
